# LLM Provider — use one
GOOGLE_API_KEY=
GROQ_API_KEY=

# Embedding model (HuggingFace — no key required for local models)
EMBEDDING_MODEL=BAAI/bge-m3

# Vector store path
VECTOR_STORE_PATH=./data/vector_store

# LangGraph settings
MAX_STEPS=10
MAX_TOOL_CALLS=3
TOP_K=5
CHUNK_SIZE=512
CHUNK_OVERLAP=64
